# PostgreSQL connection string
# Railway: automatically set via Railway PostgreSQL plugin
DATABASE_URL="postgresql://postgres:password@localhost:5432/dartbit"

# JWT secret - change this in production!
JWT_SECRET="dartbit-super-secret-jwt-key-change-in-production"

# Server port
PORT=4000

# Your backend PUBLIC URL (used in MikroTik bootstrap commands)
# Production Railway URL:
BACKEND_URL="https://dartbit-production.up.railway.app"

# Frontend URL (for CORS)
FRONTEND_URL="https://dartbit-production.up.railway.app"

NODE_ENV="production"
