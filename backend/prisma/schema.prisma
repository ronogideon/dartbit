generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  TENANT_ADMIN
}

enum ServiceType {
  PPPOE
  HOTSPOT
  STATIC
}

enum RouterStatus {
  ONLINE
  OFFLINE
  UNKNOWN
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tenant {
  id            String       @id @default(cuid())
  name          String
  subdomain     String       @unique
  domain        String?      @unique
  logoUrl       String?
  phone         String?
  isActive      Boolean      @default(true)
  status        TenantStatus @default(TRIAL)
  trialEndsAt   DateTime?
  billingDueDate DateTime?
  billingStatus String       @default("CURRENT") // CURRENT | DUE_SOON | OVERDUE | PAID
  users         User[]
  routers       MikrotikRouter[]
  subscribers   Subscriber[]
  packages      Package[]
  payments      Payment[]
  messages      Message[]
  settings      TenantSetting?
  vouchers      Voucher[]
  tenantPayments TenantPayment[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// Platform billing: a tenant's payment to the Dartbit platform (via Paystack).
model TenantPayment {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount          Float                          // KES amount invoiced
  status          String   @default("PENDING")   // PENDING | PAID | FAILED
  paystackRef     String?  @unique               // Paystack transaction reference
  paystackUrl     String?                        // checkout URL
  periodStart     DateTime                        // billing period this covers
  periodEnd       DateTime
  dueDate         DateTime
  paidAt          DateTime?
  // Breakdown snapshot at invoice time
  pppoeCount      Int      @default(0)
  pppoeCharge     Float    @default(0)
  hotspotIncome   Float    @default(0)
  hotspotCharge   Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status])
  @@index([paystackRef])
}

model MikrotikRouter {
  id             String                    @id @default(cuid())
  name           String
  host           String
  apiKey         String                    @unique @default(cuid())
  status         RouterStatus              @default(UNKNOWN)
  identity       String?
  cpuLoad        Float?
  uptime         String?
  lastSeenAt     DateTime?
  tenantId       String
  tenant         Tenant                    @relation(fields: [tenantId], references: [id])
  interfaces     RouterInterface[]
  subscribers    Subscriber[]
  provConfig     RouterProvisioningConfig?
  onlineSessions OnlineSession[]
  vouchers       Voucher[]
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
}

model RouterInterface {
  id        String         @id @default(cuid())
  name      String
  type      String
  macAddr   String?
  running   Boolean        @default(false)
  disabled  Boolean        @default(false)
  routerId  String
  router    MikrotikRouter @relation(fields: [routerId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model RouterProvisioningConfig {
  id                  String         @id @default(cuid())
  routerId            String         @unique
  router              MikrotikRouter @relation(fields: [routerId], references: [id], onDelete: Cascade)
  wanInterface        String         @default("ether1")
  lanInterface        String         @default("ether2")
  bridgeName          String         @default("bridge-lan")
  lanSubnet           String         @default("192.168.88.0/24")
  lanGateway          String         @default("192.168.88.1")
  dhcpPoolStart       String         @default("192.168.88.10")
  dhcpPoolEnd         String         @default("192.168.88.254")
  dnsServers          String         @default("8.8.8.8,8.8.4.4")
  pppoeEnabled        Boolean        @default(true)
  pppoeInterface      String         @default("bridge-lan")
  pppoeLocalAddress   String         @default("10.10.10.1")
  pppoeRemotePool     String         @default("pppoe-pool")
  pppoePoolStart      String         @default("10.10.10.10")
  pppoePoolEnd        String         @default("10.10.10.200")
  hotspotEnabled      Boolean        @default(true)
  hotspotInterface    String         @default("bridge-lan")
  hotspotNetwork      String         @default("192.168.88.0/24")
  hotspotDnsName      String         @default("dartbit.login")
  staticEnabled       Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model Subscriber {
  id           String          @id @default(cuid())
  username     String
  secret       String
  fullName     String
  phone        String?
  email        String?
  service      ServiceType     @default(PPPOE)
  isActive     Boolean         @default(true)
  expiresAt    DateTime?
  lastOnlineAt DateTime?
  ipAddress    String?
  macAddress   String?
  packageId    String?
  package      Package?        @relation(fields: [packageId], references: [id])
  routerId     String?
  router       MikrotikRouter? @relation(fields: [routerId], references: [id])
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  payments     Payment[]
  sessions     OnlineSession[]
  sessionRecords SessionRecord[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([username, tenantId])
}

model Package {
  id              String       @id @default(cuid())
  name            String
  service         ServiceType  @default(PPPOE)
  speedUpKbps     Int
  speedDownKbps   Int
  validityMinutes Int
  price           Float
  isActive        Boolean      @default(true)
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  subscribers     Subscriber[]
  vouchers        Voucher[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Payment {
  id           String     @id @default(cuid())
  amount       Float
  method       String     @default("MANUAL")
  reference    String?
  mpesaCode    String?
  notes        String?
  subscriberId String
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id])
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  type      String   @default("SMS")
  recipient String
  body      String
  status    String   @default("PENDING")
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OnlineSession {
  id            String         @id @default(cuid())
  username      String
  ipAddress     String?
  macAddress    String?
  uploadSpeed   Float?
  downloadSpeed Float?
  uptime        String?
  routerId      String
  router        MikrotikRouter @relation(fields: [routerId], references: [id], onDelete: Cascade)
  subscriberId  String?
  subscriber    Subscriber?    @relation(fields: [subscriberId], references: [id])
  tenantId      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// Persistent record of completed (and in-progress) sessions.
// startedAt set when a username first appears; endedAt set when it disappears.
// rxBytes/txBytes are the session totals (MikroTik counters at session end minus start).
model SessionRecord {
  id           String      @id @default(cuid())
  username     String
  service      ServiceType @default(PPPOE)
  ipAddress    String?
  startedAt    DateTime    @default(now())
  endedAt      DateTime?
  lastSeenAt   DateTime    @default(now())
  rxBytes      BigInt      @default(0)   // download to client (bytes)
  txBytes      BigInt      @default(0)   // upload from client (bytes)
  startRx      BigInt      @default(0)   // counter snapshot at session start
  startTx      BigInt      @default(0)
  subscriberId String?
  subscriber   Subscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)
  routerId     String?
  tenantId     String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([tenantId, subscriberId, startedAt])
  @@index([tenantId, username, startedAt])
  @@index([endedAt])
}

model TenantSetting {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  smsSenderId      String?
  smsApiKey        String?
  emailFromAddress String?
  currency         String   @default("KES")
  timezone         String   @default("Africa/Nairobi")
  backendUrl       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Voucher {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code          String    @unique
  packageId     String?
  package       Package?  @relation(fields: [packageId], references: [id])
  routerId      String?
  router        MikrotikRouter? @relation(fields: [routerId], references: [id])
  durationMinutes Int     @default(60)
  isUsed        Boolean   @default(false)
  usedAt        DateTime?
  usedByMac     String?
  usedByIp      String?
  expiresAt     DateTime?
  batchId       String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, isUsed])
  @@index([code])
  @@index([batchId])
}
