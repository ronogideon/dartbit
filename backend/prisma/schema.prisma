generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  SUPERADMIN_VIEWER
  TENANT_ADMIN
  TENANT_VIEWER
}

enum ServiceType {
  PPPOE
  HOTSPOT
  STATIC
}

enum RouterStatus {
  ONLINE
  OFFLINE
  UNKNOWN
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole
  isActive  Boolean  @default(true)
  phone     String?                  // optional; used for system alert SMS to admins
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tenant {
  id            String       @id @default(cuid())
  name          String
  subdomain     String       @unique
  domain        String?      @unique
  logoUrl       String?
  themeColor    String?                  // brand colour hex, e.g. "#2563eb"; defaults to blue
  fontFamily    String?                  // chosen font family key
  supportPhone  String?                  // shown on customer + hotspot portals; defaults to phone
  phone         String?
  isActive      Boolean      @default(true)
  status        TenantStatus @default(TRIAL)
  trialEndsAt   DateTime?
  billingDueDate DateTime?
  billingStatus String       @default("CURRENT") // CURRENT | DUE_SOON | OVERDUE | PAID
  users         User[]
  routers       MikrotikRouter[]
  subscribers   Subscriber[]
  packages      Package[]
  payments      Payment[]
  messages      Message[]
  settings      TenantSetting?
  vouchers      Voucher[]
  tenantPayments TenantPayment[]
  expenses       Expense[]
  paymentConfig PaymentConfig?
  notificationConfig NotificationConfig?
  smsWallet     SmsWallet?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// A tenant's chosen method for COLLECTING money from their own customers.
// Methods:
//   TILL_MANUAL    — Dartbit central Daraja collects; B2C payout to tenant till (1% fee)
//   PHONE_MANUAL   — Dartbit central Daraja collects; B2C payout to tenant phone (1% fee)
//   DARAJA_API     — tenant's own Daraja (Till or PayBill); money direct to tenant
//   KOPOKOPO_API   — tenant's own KopoKopo; money direct to tenant
// Sensitive credentials are stored encrypted (see utils/crypto).
model PaymentConfig {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  method          String   @default("TILL_MANUAL") // TILL_MANUAL | PHONE_MANUAL | DARAJA_API | KOPOKOPO_API

  // For manual methods (Dartbit collects, then disburses here):
  payoutTill      String?  // tenant's till number for B2C payout
  payoutPhone     String?  // tenant's phone for B2C payout

  // For DARAJA_API (tenant's own Daraja) — encrypted:
  darajaShortcode    String?  // Till or PayBill number
  darajaType         String?  // "TILL" | "PAYBILL"
  darajaConsumerKey  String?  // encrypted
  darajaConsumerSecret String? // encrypted
  darajaPasskey      String?  // encrypted (for STK)

  // For KOPOKOPO_API (tenant's own KopoKopo) — encrypted:
  kopoClientId       String?  // encrypted
  kopoClientSecret   String?  // encrypted
  kopoTillNumber     String?
  kopoApiKey         String?  // encrypted

  configured      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Platform billing: a tenant's payment to the Dartbit platform (via Paystack).
model TenantPayment {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount          Float                          // KES amount invoiced
  status          String   @default("PENDING")   // PENDING | PAID | FAILED
  paystackRef     String?  @unique               // Paystack transaction reference
  paystackUrl     String?                        // checkout URL
  periodStart     DateTime                        // billing period this covers
  periodEnd       DateTime
  dueDate         DateTime
  paidAt          DateTime?
  // Breakdown snapshot at invoice time
  pppoeCount      Int      @default(0)
  pppoeCharge     Float    @default(0)
  hotspotIncome   Float    @default(0)
  hotspotCharge   Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status])
  @@index([paystackRef])
}

// Tenant expense ledger. Auto-recorded for SMS top-ups and tenancy (Dartbit subscription)
// payments, and manually added by the tenant. Used for the Expenses tab + dashboard profit.
model Expense {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount      Float                              // KES
  category    String   @default("OTHER")         // SMS | TENANCY | OTHER (manual)
  description String?                             // free-text label
  paymentMode String?                             // e.g. M-Pesa, Cash, Bank, Card
  reference   String?                             // transaction reference / receipt
  source      String   @default("MANUAL")         // AUTO | MANUAL (whether system- or user-created)
  incurredAt  DateTime @default(now())            // when the expense happened
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, incurredAt])
}

model MikrotikRouter {
  id             String                    @id @default(cuid())
  name           String
  host           String
  apiKey         String                    @unique @default(cuid())
  status         RouterStatus              @default(UNKNOWN)
  setupStage     String                    @default("COMPLETE") // AWAITING_HEARTBEAT|AWAITING_INTERFACES|AWAITING_PORTS|COMPLETE
  identity       String?
  cpuLoad        Float?
  uptime         String?
  lastSeenAt     DateTime?
  offlineAlertSent Boolean                 @default(false) // true once an offline alert SMS was sent; reset when back online
  offlineSince     DateTime?               // when the current/last outage began (for back-online duration)
  wgIp           String?                   // assigned VPN IP, e.g. 10.8.0.11
  wgPublicKey    String?                   // router's WireGuard public key
  wgPrivateKey   String?                   // router's WireGuard private key (ENCRYPTED at rest)
  wgPeerAdded    Boolean                   @default(false) // true once the peer is registered on the droplet
  winboxPort     Int?                      @unique // stable public port on the droplet DNAT'd to this router's Winbox (8291)
  winboxOpenUntil DateTime?                // remote Winbox access auto-closes after this time
  winboxUser     String?                   // dedicated RouterOS login Dartbit provisions for tenant Winbox access
  winboxPass     String?                   // password for winboxUser (stored so the dashboard can show it)
  wgLastHandshake DateTime?                // last VPN handshake seen (for "VPN online" status)
  radiusSecret   String?                   // per-router RADIUS/CoA shared secret (for PPPoE-over-RADIUS)
  radiusEnabled  Boolean                   @default(false) // is this router using RADIUS auth?
  tenantId       String
  tenant         Tenant                    @relation(fields: [tenantId], references: [id])
  interfaces     RouterInterface[]
  subscribers    Subscriber[]
  provConfig     RouterProvisioningConfig?
  onlineSessions OnlineSession[]
  vouchers       Voucher[]
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
}

model RouterInterface {
  id        String         @id @default(cuid())
  name      String
  type      String
  macAddr   String?
  running   Boolean        @default(false)
  disabled  Boolean        @default(false)
  routerId  String
  router    MikrotikRouter @relation(fields: [routerId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model RouterProvisioningConfig {
  id                  String         @id @default(cuid())
  routerId            String         @unique
  router              MikrotikRouter @relation(fields: [routerId], references: [id], onDelete: Cascade)
  wanInterface        String         @default("ether1")
  lanInterface        String         @default("ether2")
  bridgeName          String         @default("bridge-lan")
  lanSubnet           String         @default("192.168.88.0/24")
  lanGateway          String         @default("192.168.88.1")
  dhcpPoolStart       String         @default("192.168.88.10")
  dhcpPoolEnd         String         @default("192.168.88.254")
  dnsServers          String         @default("8.8.8.8,8.8.4.4")
  pppoeEnabled        Boolean        @default(true)
  pppoeInterface      String         @default("bridge-lan")
  pppoeLocalAddress   String         @default("10.10.10.1")
  pppoeRemotePool     String         @default("pppoe-pool")
  pppoePoolStart      String         @default("10.10.10.10")
  pppoePoolEnd        String         @default("10.10.10.200")
  hotspotEnabled      Boolean        @default(true)
  hotspotInterface    String         @default("bridge-lan")
  hotspotNetwork      String         @default("192.168.88.0/24")
  hotspotDnsName      String         @default("dartbit.login")
  staticEnabled       Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model Subscriber {
  id           String          @id @default(cuid())
  username     String
  secret       String
  fullName     String
  phone        String?
  email        String?
  service      ServiceType     @default(PPPOE)
  isActive     Boolean         @default(true)
  expiresAt    DateTime?
  lastOnlineAt DateTime?
  ipAddress    String?
  macAddress   String?
  packageId    String?
  package      Package?        @relation(fields: [packageId], references: [id])
  routerId     String?
  router       MikrotikRouter? @relation(fields: [routerId], references: [id])
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  payments     Payment[]
  sessions     OnlineSession[]
  sessionRecords SessionRecord[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([username, tenantId])
}

model Package {
  id              String       @id @default(cuid())
  name            String
  service         ServiceType  @default(PPPOE)
  speedUpKbps     Int
  speedDownKbps   Int
  validityMinutes Int
  price           Float
  isTrial         Boolean      @default(false)  // free hotspot trial — MAC-only login, no payment
  isActive        Boolean      @default(true)
  routerIds       String[]     @default([])     // routers this package is offered on; empty = ALL routers
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  subscribers     Subscriber[]
  vouchers        Voucher[]
  payments        Payment[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Payment {
  id           String     @id @default(cuid())
  amount       Float
  method       String     @default("MANUAL")
  source       String     @default("MANUAL") // AUTOMATIC = gateway-created (M-Pesa callback); MANUAL = admin-recorded
  reference    String?
  mpesaCode    String?
  notes        String?
  packageId    String?                  // package this payment was for (for income-by-package analytics)
  package      Package?   @relation(fields: [packageId], references: [id], onDelete: SetNull)
  subscriberId String?
  subscriber   Subscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Message {
  id            String   @id @default(cuid())
  type          String   @default("SMS")
  recipient     String                              // phone number (full, normalized)
  body          String
  status        String   @default("PENDING")        // PENDING | SENT | FAILED | DELIVERED
  // SMS-gateway details
  gateway       String?                              // "BLESSEDTEXTS" etc.
  gatewayMsgId  String?                              // provider message_id (for delivery report lookup)
  cost          Float    @default(0)                 // KES cost reported by gateway
  errorCode     String?                              // gateway status_code on failure
  errorMessage  String?                              // gateway status_desc on failure
  // Linkage so the Messages tab can show username
  subscriberId  String?
  username      String?                              // denormalized for display
  // Categorization + deduplication for automatic notifications
  category      String?                              // WELCOME | RECEIPT | REMINDER | MANUAL | OTHER
  dedupKey      String?  @unique                     // e.g. "REMINDER:<subId>:7200" prevents double-sends
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([subscriberId])
}

model OnlineSession {
  id            String         @id @default(cuid())
  username      String
  ipAddress     String?
  macAddress    String?
  uploadSpeed   Float?
  downloadSpeed Float?
  uptime        String?
  routerId      String
  router        MikrotikRouter @relation(fields: [routerId], references: [id], onDelete: Cascade)
  subscriberId  String?
  subscriber    Subscriber?    @relation(fields: [subscriberId], references: [id], onDelete: SetNull)
  tenantId      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// Persistent record of completed (and in-progress) sessions.
// startedAt set when a username first appears; endedAt set when it disappears.
// rxBytes/txBytes are the session totals (MikroTik counters at session end minus start).
model SessionRecord {
  id           String      @id @default(cuid())
  username     String
  service      ServiceType @default(PPPOE)
  ipAddress    String?
  startedAt    DateTime    @default(now())
  endedAt      DateTime?
  lastSeenAt   DateTime    @default(now())
  rxBytes      BigInt      @default(0)   // download to client (bytes)
  txBytes      BigInt      @default(0)   // upload from client (bytes)
  startRx      BigInt      @default(0)   // counter snapshot at session start
  startTx      BigInt      @default(0)
  subscriberId String?
  subscriber   Subscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)
  routerId     String?
  tenantId     String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([tenantId, subscriberId, startedAt])
  @@index([tenantId, username, startedAt])
  @@index([endedAt])
}

model TenantSetting {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  smsSenderId      String?
  smsApiKey        String?
  emailFromAddress String?
  currency         String   @default("KES")
  timezone         String   @default("Africa/Nairobi")
  autoDeleteOfflineDays Int  @default(90) // auto-remove subscribers offline this many days (0 = never)
  backendUrl       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Voucher {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code          String    @unique
  packageId     String?
  package       Package?  @relation(fields: [packageId], references: [id])
  routerId      String?
  router        MikrotikRouter? @relation(fields: [routerId], references: [id])
  durationMinutes Int     @default(60)
  isUsed        Boolean   @default(false)
  usedAt        DateTime?
  usedByMac     String?
  usedByIp      String?
  expiresAt     DateTime?
  batchId       String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, isUsed])
  @@index([code])
  @@index([batchId])
}

// Tracks an M-Pesa STK Push transaction for a hotspot purchase.
// Lifecycle: PENDING (STK sent) -> PAID (callback success) | FAILED (callback fail/timeout)
// On PAID we provision a hotspot user (username/password) and auto-connect the captured MAC.
model MpesaTransaction {
  id                String    @id @default(cuid())
  tenantId          String
  routerId          String?
  packageId         String?
  phone             String                    // payer phone (2547...)
  amount            Float
  status            String    @default("PENDING") // PENDING | PAID | FAILED
  purpose           String?                    // null/HOTSPOT (default purchase) | SMS_TOPUP
  // Daraja identifiers
  checkoutRequestId String?   @unique          // from STK initiate response
  merchantRequestId String?
  mpesaReceipt      String?                    // M-Pesa confirmation code (on success)
  // Provisioning result
  username          String?
  subscriberId      String?                    // for PPPoE/Static renewals: the exact subscriber being paid for (payer phone may differ)
  password          String?
  clientMac         String?                    // captured from hotspot session at buy time
  clientIp          String?
  durationMinutes   Int       @default(60)
  expiresAt         DateTime?
  resultDesc        String?
  // Collection routing + payout (for Dartbit-collected manual methods)
  collectedVia      String?   @default("TENANT") // TENANT | DARTBIT
  platformFee       Float     @default(0)         // 1% fee retained by Dartbit (manual methods)
  netToTenant       Float     @default(0)         // amount owed/paid to tenant after fee
  payoutStatus      String?   // null | PENDING | PAID | FAILED
  payoutRef         String?   // B2C conversation id
  payoutAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([checkoutRequestId])
  @@index([mpesaReceipt])
}

// Persistent command queue for routers. Replaces the old in-memory queue, which
// lost commands across backend restarts / multiple instances (so reprovision and
// other queued commands silently never reached the router).
model RouterCommand {
  id        String   @id @default(cuid())
  routerId  String
  command   String                  // the RouterOS command(s) to run
  consumed  Boolean  @default(false) // set true once delivered to the router
  createdAt DateTime @default(now())

  @@index([routerId, consumed])
}

// Per-tenant SMS / notifications configuration. Stores which gateway to use (Dartbit's
// shared BlessedTexts account by default, or the tenant's own API key) and which automated
// notifications to send (welcome, payment receipt, expiry reminders).
model NotificationConfig {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Gateway
  gateway           String   @default("DARTBIT")    // DARTBIT (shared) | CUSTOM (tenant's own)
  provider          String   @default("BLESSEDTEXTS") // BLESSEDTEXTS | TALKSASA — which gateway the CUSTOM creds are for
  apiKey            String?                          // encrypted; only used when gateway=CUSTOM
  senderId          String?                          // tenant's sender ID
  // Auto notifications (defaults: on for welcome/receipt/expiry-reminders)
  sendWelcome       Boolean  @default(true)
  sendPaymentReceipt Boolean @default(true)
  sendExpiryReminders Boolean @default(true)
  // Expiry reminder offsets in minutes-before-expiry. Defaults: 5d, 3d, 4h.
  reminderOffsets   Int[]    @default([7200, 4320, 240])
  // Editable message templates (JSON map of templateKey -> text). When a key is absent the
  // built-in default is used. Keys are grouped by service: hotspot_*, pppoe_*, system_*.
  templates         Json?
  // System alerts
  alertPhones       String[] @default([])            // extra numbers for system alerts (admin phones added automatically)
  routerOfflineAlert Boolean @default(true)          // SMS when a router is offline > 5 min
  lowBalanceAlert   Boolean  @default(true)          // SMS when SMS wallet drops below threshold
  lowBalanceThreshold Float  @default(50)            // KES threshold for the low-balance alert
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Per-tenant prepaid SMS wallet. Tenants top up via M-Pesa (STK to Dartbit); each SMS sent
// through the Dartbit shared gateway debits the wallet at the configured per-SMS rate.
// Balance is derived as (sum of credits − sum of debits) but also cached here for speed.
model SmsWallet {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  balance     Float    @default(0)   // KES available
  toppedUp    Float    @default(0)   // lifetime KES topped up
  spent       Float    @default(0)   // lifetime KES spent on SMS
  lowBalanceAlerted Boolean @default(false) // true once a low-balance alert was sent; reset on top-up
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  txns        SmsWalletTxn[]
}

// Ledger of wallet movements: TOPUP (credit) and SMS_DEBIT (debit). Keeps an audit trail
// and lets us reconcile the cached balance.
model SmsWalletTxn {
  id          String   @id @default(cuid())
  walletId    String
  wallet      SmsWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  tenantId    String
  type        String   // TOPUP | SMS_DEBIT | ADJUSTMENT
  amount      Float    // positive = credit, negative = debit (KES)
  balanceAfter Float
  // For top-ups: link to the M-Pesa transaction. For debits: link to the Message.
  reference   String?  // mpesa receipt or message id
  note        String?
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
}

// Platform-wide settings (singleton-ish key/value). Used for the SMS per-message rate so it
// can be changed without a redeploy and varied per provider later.
model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  updatedAt   DateTime @updatedAt
}

// Records that a device (by MAC) has used a free trial — once per device, ever, per tenant.
// Kept SEPARATE from Subscriber so deleting the trial subscriber does NOT reset the device's
// eligibility (otherwise a device could delete-and-reclaim forever).
model TrialClaim {
  id         String   @id @default(cuid())
  tenantId   String
  macAddress String
  packageId  String?
  claimedAt  DateTime @default(now())
  @@unique([tenantId, macAddress])
  @@index([tenantId])
}

// Short-lived SMS codes for password reset (staff Users and portal Subscribers).
model PasswordResetCode {
  id        String    @id @default(cuid())
  scope     String    // 'STAFF' | 'CUSTOMER'
  subjectId String    // User.id or Subscriber.id
  codeHash  String    // bcrypt hash of the 6-digit code (never stored in clear)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  @@index([scope, subjectId])
}
